@model IEnumerable<CarShop.Domain.Entities.Car>

@{
  ViewData["Title"] = "Каталог автомобилей";
  var request = ViewContext.HttpContext.Request;
  var returnUrl = request.Path + request.QueryString.ToUriComponent();
  var categories = ViewData["categories"] as IEnumerable<Category>;
  var currentCategory = ViewData["currentCategory"]?.ToString() ?? "Все";
    
  // получаем данные пагинации
  var currentPage = ViewData["CurrentPage"] as int? ?? 1;
  var totalPages = ViewData["TotalPages"] as int? ?? 1;
  string? category = request.RouteValues["category"]?.ToString();
    
  int prev = currentPage == 1 ? 1 : currentPage - 1;
  int next = currentPage == totalPages ? totalPages : currentPage + 1;
}

<h2 class="text-center my-5 fw-bold">
  <span class="bg-gradient-primary text-black px-4 py-2 rounded-pill">Каталог автомобилей</span>
</h2>

<div class="container">
  <div class="row mb-4">
    <div class="col-12">
      <div class="dropdown">
        <button class="btn btn-outline-secondary dropdown-toggle rounded-pill px-4" type="button"
                data-bs-toggle="dropdown" aria-expanded="false">
          <i class="bi bi-funnel"></i> Фильтр: @currentCategory
        </button>
        <ul class="dropdown-menu">
          <li>
            <a class="dropdown-item @(currentCategory == "Все" ? "active" : "")" asp-controller="Car" asp-action="Index"
               asp-route-category="@null">
              <i class="bi bi-grid"></i> Все
            </a>
          </li>
          @if (categories != null)
          {
            @foreach (var cat in categories)
            {
              <li>
                <a class="dropdown-item @(currentCategory == cat.Name ? "active" : "")" asp-controller="Car"
                   asp-action="Index" asp-route-category="@cat.NormalizedName">
                  @cat.Name
                </a>
              </li>
            }
          }
        </ul>
      </div>
    </div>
  </div>

  @if (Model != null && Model.Any())
  {
    <div class="row g-4">
      @foreach (var item in Model)
      {
        <partial name="_ProductItemPartial" model="@item" />
      }
    </div>

    // информация о текущей странице
    <div class="text-start mt-4">
      <span class="text-muted">
        Страница @currentPage из @totalPages
      </span>
    </div>

    // пагинация
    @if (totalPages > 1)
    {
      <div class="row mt-3">
        <div class="col-12">
          <nav aria-label="Page navigation">
            <ul class="pagination justify-content-start">
              
              <li class="page-item @(prev == currentPage ? "disabled" : "")">
                <a class="page-link" asp-controller="Car" asp-action="Index" asp-route-pageNo="@prev"
                   asp-route-category="@category">
                  <span aria-hidden="true">&laquo;</span>
                </a>
              </li>

              @for (int i = 1; i <= totalPages; i++)
              {
                <li class="page-item @(i == currentPage ? "active" : "")">
                  <a class="page-link" asp-controller="Car" asp-action="Index" asp-route-pageNo="@i"
                     asp-route-category="@category">
                    @i
                  </a>
                </li>
              }

              <li class="page-item @(next == currentPage ? "disabled" : "")">
                <a class="page-link" asp-controller="Car" asp-action="Index" asp-route-pageNo="@next"
                   asp-route-category="@category">
                  <span aria-hidden="true">&raquo;</span>
                </a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    }
  }
  else
  {
    <div class="alert alert-warning text-center rounded-4">
      <i class="bi bi-emoji-frown fs-1"></i>
      <p class="mt-2 mb-0">@(ViewData["Error"] ?? "Нет автомобилей в выбранной категории")</p>
    </div>
  }
</div>

<style>
  .transition-all {
    transition: all 0.3s ease;
  }

  .transition-all:hover {
    transform: translateY(-8px);
    box-shadow: 0 1rem 2rem rgba(0, 0, 0, .15) !important;
  }

  .object-fit-cover {
    object-fit: cover;
  }

  .card:hover img {
    transform: scale(1.05);
  }

  .btn-outline-primary:hover {
    background: linear-gradient(135deg, #0d6efd, #0b5ed7);
    border-color: transparent;
  }
</style>