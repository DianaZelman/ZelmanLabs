@model IEnumerable<CarShop.Domain.Entities.Car>

@{
  ViewData["Title"] = "Каталог автомобилей";
  var request = ViewContext.HttpContext.Request;
  var returnUrl = request.Path + request.QueryString.ToUriComponent();
  var categories = ViewData["categories"] as IEnumerable<Category>;
  var currentCategory = ViewData["currentCategory"]?.ToString() ?? "Все";
}

<h2 class="text-center my-5 fw-bold">
  <span class="bg-gradient-primary text-black px-4 py-2 rounded-pill">Каталог автомобилей</span>
</h2>

<div class="container">
  <div class="row mb-4">
    <div class="col-12">
      <div class="dropdown">
        <button class="btn btn-outline-secondary dropdown-toggle rounded-pill px-4" type="button"
                data-bs-toggle="dropdown" aria-expanded="false">
          <i class="bi bi-funnel"></i> Фильтр: @currentCategory
        </button>
        <ul class="dropdown-menu">
          <li>
            <a class="dropdown-item @(currentCategory == "Все" ? "active" : "")" asp-controller="Car" asp-action="Index"
               asp-route-category="@null">
              <i class="bi bi-grid"></i> Все
            </a>
          </li>
          @if (categories != null)
          {
            @foreach (var cat in categories)
            {
              <li>
                <a class="dropdown-item @(currentCategory == cat.Name ? "active" : "")" asp-controller="Car"
                   asp-action="Index" asp-route-category="@cat.NormalizedName">
                  @cat.Name
                </a>
              </li>
            }
          }
        </ul>
      </div>
    </div>
  </div>

  @if (Model != null && Model.Any())
  {
    <div class="row g-4">
      @foreach (var item in Model)
      {
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden transition-all">
            <!-- изображение -->
            <div class="position-relative overflow-hidden" style="height: 220px;">
              <img class="w-100 h-100 object-fit-cover" src="@item.Image" alt="@item.Name"
                   style="transition: transform 0.3s; object-fit: cover;">
            </div>

            <!-- бейдж категории -->
            <div class="position-absolute top-0 end-0 m-3">
              <span class="badge bg-dark bg-opacity-75 rounded-pill px-3 py-2">
                <i class="bi bi-tag"></i>
                @(item.Category?.Name ?? "Автомобиль")
              </span>
            </div>

            <div class="card-body">
              <h5 class="card-title fw-bold text-dark">@item.Name</h5>
              <p class="card-text text-secondary small">@item.Description</p>

              <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="h4 text-primary fw-bold mb-0">$@item.Price.ToString("N0")</span>
                <span class="badge bg-warning text-dark rounded-pill px-3 py-2">
                  <i class="bi bi-lightning-charge"></i> @item.Horsepower л.с.
                </span>
              </div>
            </div>

            <div class="card-footer bg-transparent border-0 pb-4 pt-0">
              <a class="btn btn-outline-primary w-100 rounded-pill py-2 fw-semibold" asp-action="add" asp-controller="cart"
                 asp-route-id="@item.Id" asp-route-returnurl="@returnUrl">
                <i class="bi bi-cart-plus"></i> В корзину
              </a>
            </div>
          </div>
        </div>
      }
    </div>
  }
  else
  {
    <div class="alert alert-warning text-center rounded-4">
      <i class="bi bi-emoji-frown fs-1"></i>
      <p class="mt-2 mb-0">Нет автомобилей в выбранной категории</p>
    </div>
  }
</div>

<style>
  .transition-all {
    transition: all 0.3s ease;
  }

  .transition-all:hover {
    transform: translateY(-8px);
    box-shadow: 0 1rem 2rem rgba(0, 0, 0, .15) !important;
  }

  .object-fit-cover {
    object-fit: cover;
  }

  .card:hover img {
    transform: scale(1.05);
  }

  .btn-outline-primary:hover {
    background: linear-gradient(135deg, #0d6efd, #0b5ed7);
    border-color: transparent;
  }
</style>