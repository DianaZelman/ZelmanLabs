@using CarShop.Domain.Modeles
@model Dictionary<int, CartItem>

@{
  ViewData["Title"] = "Корзина";
}

<style>
  .description-col {
    max-width: 200px;
    word-wrap: break-word;
  }
</style>

<h1>Корзина</h1>

@if (Model == null || Model.Count == 0)
{
  <div class="alert alert-info">
    <h3>Ваша корзина пуста</h3>
    <p>Перейдите в <a asp-controller="Car" asp-action="Index">каталог</a>, чтобы добавить автомобили.</p>
  </div>
}
else
{
  <div class="table-responsive">
    <table class="table table-striped">
      <thead>
        <tr>
          <th>Изображение</th>
          <th>Название</th>
          <th class="description-col">Описание</th>
          <th>Цена</th>
          <th>Количество</th>
          <th>Сумма</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        @foreach (var item in Model)
        {
          <tr>
            <td>
              @if (!string.IsNullOrEmpty(item.Value.Item.Image))
              {
                <img src="@item.Value.Item.Image" style="width:100px; height:auto;" />
              }
            </td>
            <td><strong>@item.Value.Item.Name</strong></td>
            <td class="description-col">@item.Value.Item.Description</td>
            <td>@item.Value.Item.Price.ToString("F0") $</td>
            <td>@item.Value.Qty</td>
            <td>@((item.Value.Item.Price * item.Value.Qty).ToString("F0")) $</td>
            <td>
              <a asp-action="Remove" asp-controller="Cart" asp-route-id="@item.Value.Item.Id" class="btn btn-danger btn-sm">
                <i class="fas fa-trash"></i> Удалить
              </a>
            </td>
          </tr>
        }
      </tbody>
      <tfoot>
        <tr>
          <td colspan="5" class="text-end"><strong>Итого:</strong></td>
          <td><strong>@Model.Values.Sum(x => x.Item.Price * x.Qty).ToString("F0") $</strong></td>
          <td>
            <a asp-action="Clear" asp-controller="Cart" class="btn btn-warning btn-sm">
              <i class="fas fa-trash-alt"></i> Очистить корзину
            </a>
          </td>
        </tr>
      </tfoot>
    </table>
  </div>
}

<div class="mt-3">
  <a asp-controller="Car" asp-action="Index" class="btn btn-secondary">
    <i class="fas fa-arrow-left"></i> Продолжить покупки
  </a>
</div>